<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension"
       owl="1">

        <!-- Tighten receipt line spacing -->
        <xpath expr="//div[contains(@class,'pos-receipt-line')]" position="attributes">
            <attribute name="style">padding:2px 0 !important; gap:4px !important;</attribute>
        </xpath>

    </t>

</templates>